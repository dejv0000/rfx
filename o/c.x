      <link>https://www.chosun.com/national/people/2026/06/22/YQRPTKZQYBDL7GBBJE2LHL5MSI/</link>
      <guid isPermaLink="true">https://www.chosun.com/national/people/2026/06/22/YQRPTKZQYBDL7GBBJE2LHL5MSI/</guid>

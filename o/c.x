    <item>
      <title>[오늘의 날씨] 2026년 6월 18일</title>
      <link>https://www.chosun.com/national/national_general/2026/06/17/5OPH7RNGJVBQTGHJIDICQBBTYY/</link>
      <guid isPermaLink="true">https://www.chosun.com/national/national_general/2026/06/17/5OPH7RNGJVBQTGHJIDICQBBTYY/</guid>

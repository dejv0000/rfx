    <item>
      <title>[부음] 김혜덕씨 별세 외</title>
      <link>https://www.chosun.com/national/obituary-personnel/2026/04/22/KGQHQZLZLVA7FNXCDTBGKFR5AA/</link>
      <guid isPermaLink="true">https://www.chosun.com/national/obituary-personnel/2026/04/22/KGQHQZLZLVA7FNXCDTBGKFR5AA/</guid>
      <dc:creator>조선일보</dc:creator>

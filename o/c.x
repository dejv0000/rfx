    <item>
      <title>[오늘의 날씨] 2026년 6월 16일</title>
      <link>https://www.chosun.com/national/welfare-medical/2026/06/15/WVVR7GVPJ5BU3LFYFYGP2JEAX4/</link>
      <guid isPermaLink="true">https://www.chosun.com/national/welfare-medical/2026/06/15/WVVR7GVPJ5BU3LFYFYGP2JEAX4/</guid>

    <item>
      <title>[신문으로 배우는 실용한자] 수율(收率)</title>
      <link>https://www.chosun.com/national/nie/chinese_character/2026/06/16/I7SZTSQ2BRHHRG2D7JE2RODJ6E/</link>
      <guid isPermaLink="true">https://www.chosun.com/national/nie/chinese_character/2026/06/16/I7SZTSQ2BRHHRG2D7JE2RODJ6E/</guid>
      <dc:creator>조선일보</dc:creator>
      <description/>
      <pubDate>Mon, 15 Jun 2026 15:34:00 +0000</pubDate>

      <guid isPermaLink="true">https://www.chosun.com/national/transport-environment/2026/07/09/6JLRJZRVVFH2VAVUVAS2SOXPY4/</guid>
      <dc:creator>조선일보</dc:creator>
      <description/>
      <pubDate>Wed, 08 Jul 2026 15:50:00 +0000</pubDate>
      <content:encoded>&lt;figure&gt;&lt;img align="center" src="https://cloudfront-ap-northeast-1.images.arcpublishing.com/chosun/DFMTNNHJZ5CEJEKYJXQZ6XO6LA.jpg"&gt;&lt;figcaption&gt;&lt;small&gt;&lt;/small&gt;&lt;/figcaption&gt;&lt;/figure&gt;&lt;br&gt;&lt;br&gt;&lt;br&gt;&lt;br&gt;</content:encoded>
